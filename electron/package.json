{
  "name": "tibetan-reader",
  "version": "1.0.0",
  "description": "藏文阅读器 · Tibetan Reader - 德格版《四部医典》OCR阅读器",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:all": "electron-builder --linux --win --mac",
    "build": "electron-builder --linux"
  },
  "author": "Tibetan Reader",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.tibetan-reader.app",
    "productName": "藏文阅读器",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": ["**/*"]
      },
      {
        "from": "../data",
        "to": "data",
        "filter": ["**/*"]
      },
      {
        "from": "../frontend",
        "to": "frontend",
        "filter": ["**/*"]
      }
    ],
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "icon.png",
      "category": "Education",
      "synopsis": "Tibetan Text Reader",
      "description": "A reader for the Degé edition of the Four Medical Tantras (四部医典) with OCR text, PDF viewing, and dictionary lookup."
    },
    "win": {
      "target": ["nsis"],
      "icon": "icon.png"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "icon.png",
      "category": "public.app-category.education"
    }
  }
}
